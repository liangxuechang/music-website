<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.yin.mapper.PlayRecordMapper">
  <resultMap id="BaseResultMap" type="com.example.yin.model.domain.PlayRecord">
    <id column="id" property="id" jdbcType="INTEGER" />
    <result column="user_id" property="userId" jdbcType="INTEGER" />
    <result column="song_id" property="songId" jdbcType="INTEGER" />
    <result column="song_name" property="songName" jdbcType="VARCHAR" />
    <result column="create_time" property="createTime" jdbcType="TIMESTAMP" />
  </resultMap>
  <sql id="Base_Column_List">
    id, user_id, song_id, song_name, create_time
  </sql>

  <!-- 分页查询听歌记录，支持用户名和歌曲名称筛选 -->
  <select id="selectPlayRecordPage" resultMap="BaseResultMap">
    SELECT pr.id, pr.user_id, pr.song_id, pr.song_name, pr.create_time
    FROM play_record pr
    LEFT JOIN consumer c ON pr.user_id = c.id
    <where>
      <if test="username != null and username != ''">
        AND c.username LIKE CONCAT('%', #{username}, '%')
      </if>
      <if test="songName != null and songName != ''">
        AND pr.song_name LIKE CONCAT('%', #{songName}, '%')
      </if>
    </where>
    ORDER BY pr.create_time DESC
    LIMIT #{startIndex}, #{pageSize}
  </select>

  <!-- 查询听歌记录总数 -->
  <select id="selectPlayRecordCount" resultType="int">
    SELECT COUNT(DISTINCT pr.id)
    FROM play_record pr
    LEFT JOIN consumer c ON pr.user_id = c.id
    <where>
      <if test="username != null and username != ''">
        AND c.username LIKE CONCAT('%', #{username}, '%')
      </if>
      <if test="songName != null and songName != ''">
        AND pr.song_name LIKE CONCAT('%', #{songName}, '%')
      </if>
    </where>
  </select>
</mapper>
